// IDM Tournament App - SQLite Schema (Adapted from PostgreSQL)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Tournament {
  id           String   @id @default(cuid())
  name         String
  division     String   @default("male")
  type         String   @default("weekly")
  status       String   @default("setup")
  week         Int?
  bracketType  String?
  prizePool    Float    @default(0)
  prizeChampion Float   @default(0)
  prizeRunnerUp Float   @default(0)
  prizeThird   Float    @default(0)
  prizeMvp     Float    @default(0)
  mode         String   @default("GR Arena 3vs3")
  bpm          String   @default("130")
  lokasi       String   @default("PUB 1")
  startDate    DateTime?
  endDate      DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  matches       Match[]
  registrations Registration[]
  sawers        Sawer[]
  teams         Team[]
  bounties      Bounty[]
}

model User {
  id          String   @id @default(cuid())
  name        String
  email       String   @unique
  gender      String   @default("male")
  tier        String   @default("B")
  points      Int      @default(0)
  avatar      String?
  phone       String?
  role        String   @default("user")
  adminPass   String?
  permissions String   @default("{}")
  isAdmin     Boolean  @default(false)
  isMVP       Boolean  @default(false)
  mvpScore    Int      @default(0)
  clubId      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  city        String?
  playerPin   String?   // PIN for player login (hashed)

  // ── ELO / Skill Rating ──
  eloRating   Int      @default(1000)
  eloTier     String   @default("Bronze")
  winStreak   Int      @default(0)
  bestStreak  Int      @default(0)
  totalKills  Int      @default(0)
  totalDeaths Int      @default(0)

  donations       Donation[]
  matchesAsMvp    Match[]        @relation("UserMvpMatches")
  rankings        Ranking?
  registrations   Registration[]
  teamMembers     TeamMember[]
  club            Club?          @relation(fields: [clubId], references: [id], onDelete: SetNull)
  achievements    Achievement[]
  seasonPoints    PlayerSeason[]
  activityLogs    ActivityLog[]
  character       Character?
  wallet          Wallet?
  bountiesPlaced  Bounty[]       @relation("BountyPlacer")
  bountiesOnMe    Bounty[]       @relation("BountyTarget")
  bountyClaims    BountyClaim[]
  sentTransfers   WalletTransfer[] @relation("TransferSender")
  receivedTransfers WalletTransfer[] @relation("TransferReceiver")
  clubJoinRequests ClubJoinRequest[]
}

model Club {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  logoUrl     String?
  description String?
  motto       String?
  isRecruiting Boolean @default(true)
  createdBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members       User[]
  joinRequests  ClubJoinRequest[]
}

model Registration {
  id           String   @id @default(cuid())
  userId       String
  tournamentId String
  status       String   @default("pending")
  tierAssigned String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, tournamentId])
}

model Team {
  id            String   @id @default(cuid())
  tournamentId  String
  name          String
  seed          Int      @default(0)
  isEliminated  Boolean  @default(false)
  eliminationType String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tournament Tournament  @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  TeamMember TeamMember[]
  matchesWon  Match[]    @relation("Match_winnerIdToTeam")
  matchesAsTeamB Match[] @relation("Match_teamBIdToTeam")
  matchesAsTeamA Match[] @relation("Match_teamAIdToTeam")
}

model TeamMember {
  id     String @id @default(cuid())
  teamId String
  userId String
  role   String @default("member")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
}

model Match {
  id           String   @id @default(cuid())
  tournamentId String
  round        Int      @default(1)
  matchNumber  Int      @default(1)
  teamAId      String?
  teamBId      String?
  scoreA       Int?
  scoreB       Int?
  winnerId     String?
  mvpId        String?
  status       String   @default("pending")
  bracket      String   @default("winners")
  scheduledAt  DateTime?
  completedAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  mvp        User?      @relation("UserMvpMatches", fields: [mvpId], references: [id], onDelete: SetNull)
  winner     Team?      @relation("Match_winnerIdToTeam", fields: [winnerId], references: [id], onDelete: SetNull)
  teamB      Team?      @relation("Match_teamBIdToTeam", fields: [teamBId], references: [id], onDelete: SetNull)
  teamA      Team?      @relation("Match_teamAIdToTeam", fields: [teamAId], references: [id], onDelete: SetNull)
  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
}

model Donation {
  id            String    @id @default(cuid())
  userId        String?
  donorName     String?
  amount        Float
  message       String?
  anonymous     Boolean   @default(false)
  paymentMethod String    @default("qris")
  paymentStatus String    @default("pending")
  proofImageUrl String?
  paidAt        DateTime?
  createdAt     DateTime  @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model Sawer {
  id               String     @id @default(cuid())
  tournamentId     String?
  senderName       String
  senderAvatar     String?
  targetPlayerId   String?
  targetPlayerName String?
  amount           Float
  message          String?
  paymentMethod    String     @default("qris")
  paymentStatus    String     @default("pending")
  proofImageUrl    String?
  paidAt           DateTime?
  createdAt        DateTime   @default(now())

  tournament Tournament? @relation(fields: [tournamentId], references: [id], onDelete: SetNull)
}

model Ranking {
  id     String @id @default(cuid())
  userId String @unique
  points Int    @default(0)
  wins   Int    @default(0)
  losses Int    @default(0)
  rank   Int?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Achievement {
  id          String   @id @default(cuid())
  userId      String
  type        String
  name        String
  description String
  icon        String
  earnedAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type])
}

model ActivityLog {
  id        String   @id @default(cuid())
  action    String
  details   String?
  userId    String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model PlayerSeason {
  id        String   @id @default(cuid())
  userId    String
  season    Int
  points    Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, season])
}

model Settings {
  id          String  @id @default(cuid())
  key         String  @unique
  value       String
  description String?
}

model Notification {
  id        String   @id @default(cuid())
  type      String
  title     String
  message   String
  icon      String   @default("📢")
  data      String?
  isRead    Boolean  @default(false)
  userId    String?
  createdAt DateTime @default(now())
}

model VideoHighlight {
  id          String   @id @default(cuid())
  title       String
  youtubeUrl  String
  division    String   @default("all")
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model WhatsAppSettings {
  id               String    @id @default(cuid())
  provider         String    @default("baileys")
  isActive         Boolean   @default(true)
  lastConnectedAt  DateTime?
  connectionStatus String    @default("disconnected")
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model Character {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  gender    String    @default("male")
  universe  String
  alignment String
  classType String
  colors    String
  imageUrl  String?
  isTaken   Boolean   @default(false)
  takenBy   String?   @unique
  takenAt   DateTime?

  user User? @relation(fields: [takenBy], references: [id], onDelete: SetNull)
}

// ═══════════════════════════════════════════════════════════════════════
// BOUNTIE CLONE — Bounty, Wallet, ELO, Club Management
// ═══════════════════════════════════════════════════════════════════════

model Bounty {
  id              String   @id @default(cuid())
  placerId        String   // who placed the bounty
  targetPlayerId  String   // who the bounty is on
  tournamentId    String?  // optional: tied to a specific tournament
  amount          Float    @default(0)
  currency        String   @default("points") // points or rp (real money)
  reason          String?  // why the bounty was placed
  status          String   @default("active")  // active, claimed, expired, cancelled
  expiresAt       DateTime?
  claimedAt       DateTime?
  claimedById     String?  // who collected the bounty
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  placer         User          @relation("BountyPlacer", fields: [placerId], references: [id], onDelete: Cascade)
  targetPlayer   User          @relation("BountyTarget", fields: [targetPlayerId], references: [id], onDelete: Cascade)
  tournament     Tournament?   @relation(fields: [tournamentId], references: [id], onDelete: SetNull)
  claims         BountyClaim[]
}

model BountyClaim {
  id        String   @id @default(cuid())
  bountyId  String
  claimerId String   // who beat the target and claims the bounty
  matchId   String?  // the match where the target was defeated
  proof     String?  // screenshot/description
  status    String   @default("pending") // pending, approved, rejected
  reviewedBy String?
  reviewedAt DateTime?
  createdAt DateTime @default(now())

  bounty    Bounty   @relation(fields: [bountyId], references: [id], onDelete: Cascade)
  claimer   User     @relation(fields: [claimerId], references: [id], onDelete: Cascade)
}

model Wallet {
  id        String   @id @default(cuid())
  userId    String   @unique
  balance   Float    @default(0)
  totalIn   Float    @default(0)
  totalOut  Float    @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions WalletTransaction[]
}

model WalletTransaction {
  id          String   @id @default(cuid())
  walletId    String
  type        String   // credit, debit
  amount      Float
  category    String   // bounty_place, bounty_claim, prize, topup, withdraw, sawer, donation
  description String?
  referenceId String?  // related entity ID (bounty, tournament, etc)
  createdAt   DateTime @default(now())

  wallet      Wallet   @relation(fields: [walletId], references: [id], onDelete: Cascade)
}

model WalletTransfer {
  id          String   @id @default(cuid())
  senderId    String
  receiverId  String
  amount      Float
  reason      String?
  status      String   @default("completed") // pending, completed, cancelled
  createdAt   DateTime @default(now())

  sender      User     @relation("TransferSender", fields: [senderId], references: [id], onDelete: Cascade)
  receiver    User     @relation("TransferReceiver", fields: [receiverId], references: [id], onDelete: Cascade)
}

model ClubJoinRequest {
  id        String   @id @default(cuid())
  clubId    String
  userId    String
  message   String?
  status    String   @default("pending") // pending, approved, rejected
  reviewedBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  club      Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([clubId, userId])
}

model MatchmakingQueue {
  id        String   @id @default(cuid())
  userId    String
  division  String   @default("male")
  eloRange  String   @default("any") // any, narrow, wide
  status    String   @default("waiting") // waiting, matched, cancelled
  matchedWith String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
