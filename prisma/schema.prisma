// IDM Tournament App - SQLite Schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model ActivityLog {
  id        String   @id @default(cuid())
  action    String
  details   String?
  userId    String?
  createdAt DateTime @default(now())
}

model BotLog {
  id           String    @id @default(cuid())
  platform     String
  command      String
  sender       String?
  senderId     String?
  response     String?
  success      Boolean   @default(true)
  tournamentId String?
  createdAt    DateTime  @default(now())
}

model Character {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  gender    String    @default("male")
  universe  String
  alignment String
  classType String
  colors    String
  imageUrl  String?
  isTaken   Boolean   @default(false)
  takenBy   String?   @unique
  takenAt   DateTime?
  user      User?     @relation(fields: [takenBy], references: [id], onDelete: SetNull)
}

model Club {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  logoUrl   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  members   User[]
}

model Donation {
  id            String    @id @default(cuid())
  userId        String?
  donorName     String?
  amount        Float
  message       String?
  anonymous     Boolean   @default(false)
  paymentMethod String    @default("qris")
  paymentStatus String    @default("pending")
  proofImageUrl String?
  paidAt        DateTime?
  createdAt     DateTime  @default(now())
  user          User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model Match {
  id                        String            @id @default(cuid())
  tournamentId              String
  round                     Int               @default(1)
  matchNumber               Int               @default(1)
  teamAId                   String?
  teamBId                   String?
  scoreA                    Int?
  scoreB                    Int?
  winnerId                  String?
  mvpId                     String?
  status                    String            @default("pending")
  bracket                   String            @default("winners")
  scheduledAt               DateTime?
  completedAt               DateTime?
  createdAt                 DateTime          @default(now())
  updatedAt                 DateTime          @updatedAt
  mvp                       User?             @relation("UserMvpMatches", fields: [mvpId], references: [id], onDelete: SetNull)
  winner                    Team?             @relation("Match_winnerIdToTeam", fields: [winnerId], references: [id], onDelete: SetNull)
  teamB                     Team?             @relation("Match_teamBIdToTeam", fields: [teamBId], references: [id], onDelete: SetNull)
  teamA                     Team?             @relation("Match_teamAIdToTeam", fields: [teamAId], references: [id], onDelete: SetNull)
  tournament                Tournament        @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  PlayerMatchStat           PlayerMatchStat[]
}

model PlayerMatchStat {
  id      String @id @default(cuid())
  matchId String
  userId  String
  score   Int    @default(0)
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  match   Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@unique([matchId, userId])
}

model Ranking {
  id     String @id @default(cuid())
  userId String @unique
  points Int    @default(0)
  wins   Int    @default(0)
  losses Int    @default(0)
  rank   Int?
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Registration {
  id           String     @id @default(cuid())
  userId       String
  tournamentId String
  status       String     @default("pending")
  tierAssigned String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, tournamentId])
}

model Sawer {
  id               String      @id @default(cuid())
  tournamentId     String?
  senderName       String
  senderAvatar     String?
  targetPlayerId   String?
  targetPlayerName String?
  amount           Float
  message          String?
  paymentMethod    String      @default("qris")
  paymentStatus    String      @default("pending")
  proofImageUrl    String?
  paidAt           DateTime?
  createdAt        DateTime    @default(now())
  tournament       Tournament? @relation(fields: [tournamentId], references: [id], onDelete: SetNull)
}

model Settings {
  id          String  @id @default(cuid())
  key         String  @unique
  value       String
  description String?
}

model Team {
  id                         String       @id @default(cuid())
  tournamentId               String
  name                       String
  seed                       Int          @default(0)
  isEliminated               Boolean      @default(false)
  eliminationType            String?
  createdAt                  DateTime     @default(now())
  updatedAt                  DateTime     @updatedAt
  matchesWon                 Match[]      @relation("Match_winnerIdToTeam")
  matchesAsTeamB             Match[]      @relation("Match_teamBIdToTeam")
  matchesAsTeamA             Match[]      @relation("Match_teamAIdToTeam")
  tournament                 Tournament   @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  TeamMember                 TeamMember[]
}

model TeamMember {
  id     String @id @default(cuid())
  teamId String
  userId String
  role   String @default("member")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
}

model Tournament {
  id           String         @id @default(cuid())
  name         String
  division     String
  type         String
  status       String         @default("setup")
  week         Int?
  bracketType  String?
  prizePool    Float          @default(0)
  prizeChampion Float         @default(0)
  prizeRunnerUp Float         @default(0)
  prizeThird   Float          @default(0)
  prizeMvp     Float          @default(0)
  mode         String         @default("GR Arena 3vs3")
  bpm          String         @default("130")
  lokasi       String         @default("PUB 1")
  startDate    DateTime?
  endDate      DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  matches      Match[]
  registrations Registration[]
  sawers       Sawer[]
  teams        Team[]
}

model User {
  id              String            @id @default(cuid())
  name            String
  email           String            @unique
  gender          String            @default("male")
  tier            String            @default("B")
  points          Int               @default(0)
  avatar          String?
  phone           String?
  whatsappJid     String?
  discordId       String?
  role            String            @default("user")
  adminPass       String?
  permissions     String            @default("{}")
  isAdmin         Boolean           @default(false)
  isMVP           Boolean           @default(false)
  mvpScore        Int               @default(0)
  clubId          String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  city            String?
  character       Character?
  donations       Donation[]
  matchesAsMvp    Match[]           @relation("UserMvpMatches")
  playerMatchStats PlayerMatchStat[]
  rankings        Ranking?
  registrations   Registration[]
  teamMembers     TeamMember[]
  club            Club?             @relation(fields: [clubId], references: [id], onDelete: SetNull)
  achievements    Achievement[]
}

model Achievement {
  id          String   @id @default(cuid())
  userId      String
  type        String
  name        String
  description String
  icon        String
  earnedAt    DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type])
}

model Notification {
  id        String   @id @default(cuid())
  type      String
  title     String
  message   String
  icon      String   @default("📢")
  data      String?
  isRead    Boolean  @default(false)
  userId    String?
  createdAt DateTime @default(now())
}

model WhatsAppSettings {
  id                     String    @id @default(cuid())
  provider               String    @default("baileys")
  isActive               Boolean   @default(true)
  metaAccessToken        String?
  metaPhoneNumberId      String?
  metaBusinessAccountId  String?
  metaWebhookVerifyToken String?
  metaAppSecret          String?
  metaApiEnabled         Boolean   @default(false)
  baileysEnabled         Boolean   @default(true)
  lastConnectedAt        DateTime?
  connectionStatus       String    @default("disconnected")
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
}
